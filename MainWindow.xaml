<Window x:Class="EasyBinds.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasyBinds"
        Width="820" Height="560"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI, sans-serif"
        Foreground="{DynamicResource TextBrush}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d0000"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource ListAltBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ListSelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource StatusBarBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource DimTextBrush}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Name="TitleBlock" FontSize="20" FontWeight="700"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Name="SubtitleText" FontSize="12"
                               Foreground="{DynamicResource DimTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Admin + Theme + Language toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="WhyAdminBtn" Width="36" Height="36"
                            ToolTip="Why?"
                            Style="{StaticResource ModernButton}"
                            FontSize="14" FontWeight="Bold" Padding="0"
                            Click="WhyAdminBtn_Click"/>
                    <Button Name="AdminBtn" Width="36" Height="36"
                            ToolTip="Admin"
                            Style="{StaticResource ModernButton}"
                            FontSize="14" Padding="0"
                            Click="AdminBtn_Click" Margin="4,0,0,0"/>
                    <Separator Width="1" Background="{DynamicResource BorderBrush}"
                               Margin="8,2" Height="20"/>
                    <Button Name="ThemeToggle" Width="36" Height="36"
                            ToolTip="Theme"
                            Style="{StaticResource ModernButton}"
                            FontSize="16" Padding="0"
                            Click="ThemeToggle_Click"/>
                    <Button Name="LangToggle" Width="36" Height="36"
                            ToolTip="Language"
                            Style="{StaticResource ModernButton}"
                            FontSize="14" FontWeight="Bold" Padding="0"
                            Click="LangToggle_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Name="AddBtn" Style="{StaticResource AccentButton}"
                        Click="AddBinding_Click"/>
                <Button Name="EditBtn" Style="{StaticResource ModernButton}"
                        Click="EditBinding_Click"/>
                <Button Name="DelBtn" Style="{StaticResource DangerButton}"
                        Click="DeleteBinding_Click"/>
                <Separator Width="1" Background="{DynamicResource BorderBrush}"
                           Margin="8,2" Height="20"/>
                <Button Name="EnableAllBtn" Style="{StaticResource ModernButton}"
                        Click="EnableAll_Click"/>
                <Button Name="DisableAllBtn" Style="{StaticResource ModernButton}"
                        Click="DisableAll_Click"/>
            </StackPanel>
        </Border>

        <!-- Binding list -->
        <Border Grid.Row="2" Margin="16,8,16,8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <ListView Name="BindingsList"
                          SelectionMode="Single"
                          MouseDoubleClick="BindingsList_MouseDoubleClick"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Enabled" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                  HorizontalAlignment="Center"
                                                  Click="BindingCheckbox_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Hotkey" Width="170"
                                            DisplayMemberBinding="{Binding HotkeyDisplay}"/>
                            <GridViewColumn Header="Action" Width="160"
                                            DisplayMemberBinding="{Binding ActionTypeDisplay}"/>
                            <GridViewColumn Header="Parameter" Width="350"
                                            DisplayMemberBinding="{Binding ActionParameter}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Name="EmptyText"
                           Foreground="{DynamicResource DimTextBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Visible"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar Grid.Row="3" Height="32">
            <StatusBarItem>
                <TextBlock Name="StatusText" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <CheckBox Name="StartWithWindowsCheck"
                          FontSize="12"
                          Checked="StartWithWindows_Changed"
                          Unchecked="StartWithWindows_Changed"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
