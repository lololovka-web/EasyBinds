<Application x:Class="EasyBinds.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0d1117"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#161b22"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1c2333"/>
        <SolidColorBrush x:Key="TextBrush" Color="#e6edf3"/>
        <SolidColorBrush x:Key="DimTextBrush" Color="#8b949e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0ea5e9"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#38bdf8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363d"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#21262d"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#30363d"/>
        <SolidColorBrush x:Key="ListAltBrush" Color="#161b22"/>
        <SolidColorBrush x:Key="ListSelectedBrush" Color="#2a1f5e"/>
        <SolidColorBrush x:Key="StatusBarBrush" Color="#161b22"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#f85149"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#3fb950"/>
    </Application.Resources>
</Application>
